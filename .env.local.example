# Astria Vars (AI service)
# Get API key - https://www.astria.ai/users/edit#api
ASTRIA_API_KEY=your-astria-api-key
# If enabled, Astria will be enabled in test mode which will not charge you, but will return dummy results.
ASTRIA_TEST_MODE=true
PACK_QUERY_TYPE=both # Options: 'users', 'gallery', 'both'
NEXT_PUBLIC_TUNE_TYPE=packs #Options: 'packs', 'tune'


# This can be any random string, it is used to secure the webhook endpoint.
APP_WEBHOOK_SECRET=your-webhook-secret

# With vercel deploy supabase env vars are auto generated!
# Configure auth magic link & redirect urls > https://github.com/leap-ai/headshots-starter#5-magic-link-auth-supabase
# Locally get Supabase details from your project settings > API - https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# VERCEL BLOB VARS (Image storage service)
BLOB_READ_WRITE_TOKEN=your-blob-read-write-token

# RESEND VARS (Email service — https://resend.com/api-keys)
RESEND_API_KEY=your-resend-api-key
# Optional: verified domain sender (default SnapProHead <contact@snapprohead.com>)
# RESEND_FROM_EMAIL=SnapProHead <contact@snapprohead.com>

# STRIPE VARS (Payment service)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_PRICE_ID_ONE_CREDIT=your-stripe-price-id-one-credit
STRIPE_PRICE_ID_THREE_CREDITS=your-stripe-price-id-three-credit
STRIPE_PRICE_ID_FIVE_CREDITS=your-stripe-price-id-five-credit
NEXT_PUBLIC_STRIPE_IS_ENABLED=false # set to true to enable Stripe payments

# SENTRY (Error monitoring - free tier: 5K events/month)
# Get DSN from: https://sentry.io → Settings → Projects → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-name

# DEPLOYMENT (required in production for Astria webhooks)
DEPLOYMENT_PROVIDER=vercel # or replit
DEPLOYMENT_URL=snapprohead.com # production: snapprohead.com (no path). Local: ngrok tunnel host.

# CREEM (Payment)
CREEM_API_KEY=your-creem-api-key
CREEM_WEBHOOK_SECRET=your-creem-webhook-secret
NEXT_PUBLIC_CREEM_IS_ENABLED=true

# OPS — payment alerts (optional, pick one or more)
# OpenClaw 个人微信（你已对接 openclaw-weixin 时优先用这个）
# 方式 A：自定义转发 URL（OpenClaw 服务器上自己写个小接口转发到微信）
OPENCLAW_NOTIFY_URL=
OPENCLAW_NOTIFY_TOKEN=
# 方式 B：直连 OpenClaw Gateway hooks（/hooks/agent）
OPENCLAW_GATEWAY_URL=https://your-openclaw-server:18789
OPENCLAW_HOOK_TOKEN=
OPENCLAW_WECHAT_TO=your-id@im.wechat
OPENCLAW_WECHAT_ACCOUNT_ID=
# OPENCLAW_WECHAT_CHANNEL=openclaw-weixin
# OPENCLAW_AGENT_ID=main
# Telegram: message @BotFather → create bot → get chat id via getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# 微信推送 PushPlus: https://www.pushplus.plus 关注公众号 → 复制 token → 完成实名认证
PUSHPLUS_TOKEN=
# 企业微信群机器人 webhook URL（群设置 → 群机器人 → 添加）
WECOM_WEBHOOK_URL=
# Sales Radar page: /ops/sales-radar?token=... (long random string; plays cha-ching when page is open)
OPS_RADAR_TOKEN=
# Google OAuth (consent screen shows your domain, not supabase.co)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Announcement Bar Configuration
NEXT_PUBLIC_ANNOUNCEMENT_ENABLED=true # set to true to enable the announcement bar
NEXT_PUBLIC_ANNOUNCEMENT_MESSAGE="🎉 We just improved our homepage, Packs now available and launched the image inspection feature!" # set the message to display in the announcement bar

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX # your Google Analytics measurement ID
